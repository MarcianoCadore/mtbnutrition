# ===== MTB Nutrition — variáveis de ambiente =====
# Copie para .env e preencha. NUNCA commitar o .env real.

# --- Banco (MongoDB Atlas em produção) ---
# Pegue a connection string no Atlas: Database > Connect > Drivers.
# Troque <password> pela senha do usuário do banco e mantenha o nome do db fora.
MONGODB_URL=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# --- Login do portal (HTTP Basic) ---
# Se PORTAL_PASSWORD ficar vazio, o portal fica SEM proteção (só p/ dev local).
PORTAL_USER=marciano
PORTAL_PASSWORD=troque-por-uma-senha-forte

# --- Diretório persistente dos arquivos .fit (em produção) ---
UPLOADS_DIR=/opt/mtbnutrition/uploads/fit

# --- IA ---
GEMINI_API_KEY=

# --- Twilio / WhatsApp ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
WHATSAPP_FROM=+14155238886
WHATSAPP_TO=+55XXXXXXXXXXX
TWILIO_CONTENT_SID=

# --- Garmin Connect ---
GARMIN_EMAIL=
GARMIN_PASSWORD=
